DEBUG=False
SECRET_KEY={{ vault_secret_key }}
ALLOWED_HOSTS={{ vault_allowed_hosts }}
CSRF_TRUSTED_ORIGINS={{ vault_csrf_trusted_origins }}

DATABASE_URL=postgresql://{{ vault_db_user }}:{{ vault_db_password }}@db:5432/{{ vault_db_name }}
POSTGRES_USER={{ vault_db_user }}
POSTGRES_PASSWORD={{ vault_db_password }}
POSTGRES_DB={{ vault_db_name }}

CACHE_BACKEND=redis
CACHE_LOCATION=redis://redis:6379/0
CACHE_TIMEOUT=300

USE_HTTPS=True
LANGUAGE_CODE=ru
TIME_ZONE=UTC

STATIC_URL=/static/
MEDIA_URL=/media/
LOGIN_URL=/users/login/
