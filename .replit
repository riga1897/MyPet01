modules = ["ruff-0.4.4", "python-3.12", "postgresql-16"]

[[ports]]
localPort = 5000
externalPort = 80

[agent]
expertMode = true

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Run Django App"

[[workflows.workflow]]
name = "Run Django App"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "poetry run python manage.py runserver 0.0.0.0:5000 --noreload"
waitForPort = 5000
