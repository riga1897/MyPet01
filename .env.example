# ========================================
# ШАБЛОН КОНФИГУРАЦИИ MyPet01
# ========================================
# Скопируйте этот файл в .env и заполните значения.
# Для VPS используйте скрипты scripts/generate-*.sh

# ========================================
# ОСНОВНЫЕ НАСТРОЙКИ
# ========================================

DEBUG=True
SECRET_KEY=django-insecure-dev-key-change-in-production
ALLOWED_HOSTS=*

# ========================================
# БАЗА ДАННЫХ
# ========================================
# DATABASE_URL имеет приоритет над отдельными POSTGRES_* параметрами

DATABASE_URL=
POSTGRES_DB=blog_db
POSTGRES_USER=blog_user
POSTGRES_PASSWORD=blog_password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ========================================
# CSRF
# ========================================

CSRF_TRUSTED_ORIGINS=https://*.replit.dev,https://*.repl.co,https://*.pike.replit.dev
CSRF_COOKIE_HTTPONLY=True
CSRF_COOKIE_SAMESITE=Lax

# ========================================
# БЕЗОПАСНОСТЬ
# ========================================

USE_HTTPS=False

# ========================================
# ЛОКАЛИЗАЦИЯ
# ========================================

LANGUAGE_CODE=ru
TIME_ZONE=UTC
USE_I18N=True
USE_TZ=True

# ========================================
# URL-АДРЕСА
# ========================================

STATIC_URL=/static/
MEDIA_URL=/media/
LOGIN_URL=/users/login/
LOGIN_REDIRECT_URL=/
LOGOUT_REDIRECT_URL=/

# ========================================
# КЭШ (СЕРВЕР)
# ========================================
# CACHE_BACKEND: locmem, db, redis, memcached
# CACHE_LOCATION: для locmem - имя, для redis - redis://host:port/db

CACHE_BACKEND=locmem
CACHE_LOCATION=mypet-cache
CACHE_TIMEOUT=300

# ========================================
# КЭШ (БРАУЗЕР)
# ========================================

BROWSER_CACHE_ENABLED=False
BROWSER_CACHE_MAX_AGE=86400

# ========================================
# АДМИНКА
# ========================================

ADMIN_SHOW_FACETS=True
