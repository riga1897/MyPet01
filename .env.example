# ========================================
# Django Settings
# ========================================
DEBUG=True
SECRET_KEY=your-secret-key-here
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,.replit.app

# ========================================
# Database (выберите один вариант)
# ========================================

# Вариант 1: Полный URL подключения
DATABASE_URL=postgres://user:password@localhost:5432/dbname

# Вариант 2: Отдельные параметры (если DATABASE_URL не задан)
# POSTGRES_USER=blog_user
# POSTGRES_PASSWORD=blog_password
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_DB=blog_db

# ========================================
# CSRF Settings
# ========================================
CSRF_TRUSTED_ORIGINS=https://yourdomain.com
CSRF_COOKIE_HTTPONLY=True
CSRF_COOKIE_SAMESITE=Lax

# ========================================
# Localization
# ========================================
LANGUAGE_CODE=ru
TIME_ZONE=UTC
USE_I18N=True
USE_TZ=True

# ========================================
# Security Settings
# ========================================

# Главный переключатель HTTPS (включает все настройки безопасности)
# Установите True когда настроите SSL-сертификат
USE_HTTPS=False

# Индивидуальные настройки (переопределяют USE_HTTPS)
# SECURE_SSL_REDIRECT=False
# SECURE_HSTS_SECONDS=0
# SECURE_HSTS_INCLUDE_SUBDOMAINS=False
# SECURE_HSTS_PRELOAD=False
# SESSION_COOKIE_SECURE=False
# CSRF_COOKIE_SECURE=False

# Security headers (всегда включены)
SECURE_BROWSER_XSS_FILTER=True
SECURE_CONTENT_TYPE_NOSNIFF=True
X_FRAME_OPTIONS=DENY

# ========================================
# Admin Settings
# ========================================

# Показывать счетчики в фильтрах админки (True = всегда, False = никогда)
ADMIN_SHOW_FACETS=True
