# Django Settings
DEBUG=True
SECRET_KEY=your-secret-key-here
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,.replit.app

# Database
# For Replit, use DATABASE_URL from secrets
DATABASE_URL=postgres://user:password@localhost:5432/dbname

# Redis
REDIS_URL=redis://localhost:6379/0

# Название базы данных
POSTGRES_DB=lms_db

# Пользователь PostgreSQL
POSTGRES_USER=lms_user

# Пароль PostgreSQL (измените в production!)
POSTGRES_PASSWORD=lms_password

# Хост базы данных (docker-compose автоматически заменит на 'db')
POSTGRES_HOST=localhost

# Порт PostgreSQL
POSTGRES_PORT=5432

# URL для статических файлов
STATIC_URL=/static/

# URL для медиа файлов (uploads)
MEDIA_URL=/media/