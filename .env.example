# ========================================
# ШАБЛОН КОНФИГУРАЦИИ MyPet01
# ========================================
# Скопируйте этот файл в .env и заполните значения.
# Затем создайте .env.development и .env.production для специфичных настроек.

# ========================================
# ВЫБОР ОКРУЖЕНИЯ
# ========================================
# Вариант 1: Через .env (рекомендуется для локальной разработки)
#   Измените значение ниже на 'production' для production-сервера
#
# Вариант 2: Через переменную окружения (рекомендуется для Docker)
#   В docker-compose.yml:
#   environment:
#     - DJANGO_ENV=production
#   Переменная окружения имеет приоритет над .env
#
DJANGO_ENV=development

# ========================================
# ОБЩИЕ НАСТРОЙКИ (одинаковые для всех окружений)
# ========================================

# Локализация
LANGUAGE_CODE=ru
TIME_ZONE=UTC
USE_I18N=True
USE_TZ=True

# URL-адреса
STATIC_URL=/static/
MEDIA_URL=/media/
LOGIN_URL=/users/login/
LOGIN_REDIRECT_URL=/
LOGOUT_REDIRECT_URL=/

# CSRF
CSRF_COOKIE_HTTPONLY=True
CSRF_COOKIE_SAMESITE=Lax

# Кэш (время жизни в секундах)
CACHE_TIMEOUT=300

# Браузерный кэш (max-age в секундах)
BROWSER_CACHE_MAX_AGE=86400

# Админка
ADMIN_SHOW_FACETS=True

# ========================================
# СПЕЦИФИЧНЫЕ НАСТРОЙКИ
# ========================================
# Эти переменные должны быть в .env.development или .env.production

# --- Основные ---
# DEBUG=True                    # development: True, production: False
# SECRET_KEY=your-secret-key    # Генерация: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
# ALLOWED_HOSTS=*               # development: *, production: your-domain.com

# --- База данных ---
# DATABASE_URL=postgresql://user:password@host:5432/dbname
# или отдельные параметры:
# POSTGRES_DB=mypet
# POSTGRES_USER=mypet_user
# POSTGRES_PASSWORD=secure_password
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432

# --- Безопасность ---
# USE_HTTPS=False               # development: False, production: True
# CSRF_TRUSTED_ORIGINS=https://*.replit.dev

# --- Кэш ---
# CACHE_BACKEND=locmem          # development: locmem, production: redis
# CACHE_LOCATION=mypet-cache    # development: mypet-cache, production: redis://redis:6379/0

# --- Браузерный кэш ---
# BROWSER_CACHE_ENABLED=False   # development: False, production: True
