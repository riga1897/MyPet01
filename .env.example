# ========================================
# ОСНОВНЫЕ НАСТРОЙКИ DJANGO
# ========================================
DEBUG=True
SECRET_KEY=your-secret-key-here
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,.replit.app

# ========================================
# БАЗА ДАННЫХ (выберите один вариант)
# ========================================

# Вариант 1: Полный URL подключения
DATABASE_URL=postgres://user:password@localhost:5432/dbname

# Вариант 2: Отдельные параметры (если DATABASE_URL не задан)
# POSTGRES_USER=blog_user
# POSTGRES_PASSWORD=blog_password
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_DB=blog_db

# ========================================
# БЕЗОПАСНОСТЬ (HTTPS)
# ========================================
# Главный переключатель (включает все настройки безопасности)
USE_HTTPS=False

# Индивидуальные настройки (переопределяют USE_HTTPS)
# SECURE_SSL_REDIRECT=False
# SECURE_HSTS_SECONDS=0
# SESSION_COOKIE_SECURE=False
# CSRF_COOKIE_SECURE=False

CSRF_TRUSTED_ORIGINS=https://yourdomain.com
CSRF_COOKIE_HTTPONLY=True
CSRF_COOKIE_SAMESITE=Lax

# Security headers (всегда включены)
SECURE_BROWSER_XSS_FILTER=True
SECURE_CONTENT_TYPE_NOSNIFF=True
X_FRAME_OPTIONS=DENY

# ========================================
# ЛОКАЛИЗАЦИЯ
# ========================================
LANGUAGE_CODE=ru
TIME_ZONE=UTC
USE_I18N=True
USE_TZ=True

# ========================================
# АДМИНКА
# ========================================
ADMIN_SHOW_FACETS=True

# ========================================
# СЕРВЕРНЫЙ КЭШ (Django)
# ========================================
# Варианты: locmem, db, redis, memcached
CACHE_BACKEND=locmem

# Для locmem: любое имя
# Для db: имя таблицы (cache_table)
# Для redis: redis://localhost:6379/1
# Для memcached: 127.0.0.1:11211
CACHE_LOCATION=mypet-cache

# Время жизни кэша в секундах (300 = 5 минут)
CACHE_TIMEOUT=300

# ========================================
# БРАУЗЕРНЫЙ КЭШ (HTTP-заголовки)
# ========================================
# Включить Cache-Control заголовки
BROWSER_CACHE_ENABLED=False

# max-age в секундах (86400 = 1 день)
BROWSER_CACHE_MAX_AGE=86400
