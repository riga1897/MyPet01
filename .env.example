# Django Settings
DEBUG=True
SECRET_KEY=your-secret-key-here
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,.replit.app

# Database
DATABASE_URL=postgres://user:password@localhost:5432/dbname

# Redis
REDIS_URL=redis://localhost:6379/0

# PostgreSQL (alternative to DATABASE_URL)
POSTGRES_DB=blog_db
POSTGRES_USER=blog_user
POSTGRES_PASSWORD=blog_password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# CSRF Settings
CSRF_TRUSTED_ORIGINS=https://yourdomain.com
CSRF_COOKIE_SECURE=False
CSRF_COOKIE_HTTPONLY=True
CSRF_COOKIE_SAMESITE=Lax

# Localization
LANGUAGE_CODE=ru
TIME_ZONE=UTC
USE_I18N=True
USE_TZ=True

# ========================================
# Production Security Settings
# Enable these when HTTPS is configured
# ========================================

# Redirect HTTP -> HTTPS (enable in production)
SECURE_SSL_REDIRECT=False

# HSTS: Browser remembers site is HTTPS-only
# Recommended: 31536000 (1 year) for production
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False

# Secure cookies (HTTPS only)
SESSION_COOKIE_SECURE=False

# Security headers (enabled by default)
SECURE_BROWSER_XSS_FILTER=True
SECURE_CONTENT_TYPE_NOSNIFF=True
X_FRAME_OPTIONS=DENY

# ========================================
# Admin Settings
# ========================================

# Show facet counters in admin filters (True = always show, False = never show)
ADMIN_SHOW_FACETS=True
