# ========================================
# ШАБЛОН КОНФИГУРАЦИИ MyPet01
# ========================================
# Скопируйте этот файл в .env.development или .env.production
# и заполните значения для вашего окружения.

# ========================================
# ОБЩИЕ НАСТРОЙКИ (.env)
# ========================================

# Локализация
LANGUAGE_CODE=ru
TIME_ZONE=UTC
USE_I18N=True
USE_TZ=True

# URL-адреса
STATIC_URL=/static/
MEDIA_URL=/media/
LOGIN_URL=/users/login/
LOGIN_REDIRECT_URL=/
LOGOUT_REDIRECT_URL=/

# CSRF
CSRF_COOKIE_HTTPONLY=True
CSRF_COOKIE_SAMESITE=Lax

# Кэш (время жизни в секундах)
CACHE_TIMEOUT=300

# Браузерный кэш (max-age в секундах)
BROWSER_CACHE_MAX_AGE=86400

# Админка
ADMIN_SHOW_FACETS=True

# ========================================
# СПЕЦИФИЧНЫЕ ДЛЯ ОКРУЖЕНИЯ (.env.development или .env.production)
# ========================================

# Development: True, Production: False
DEBUG=False

# Генерация: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-secret-key-here

# Development: *, Production: your-domain.com
ALLOWED_HOSTS=*

# База данных (вариант 1: URL)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# База данных (вариант 2: отдельные параметры)
POSTGRES_DB=mypet
POSTGRES_USER=mypet_user
POSTGRES_PASSWORD=secure_password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Development: https://*.replit.dev, Production: https://your-domain.com
CSRF_TRUSTED_ORIGINS=https://*.replit.dev,https://*.repl.co

# Development: False, Production: True
USE_HTTPS=False

# Development: locmem, Production: redis
CACHE_BACKEND=locmem
CACHE_LOCATION=mypet-cache

# Development: False, Production: True
BROWSER_CACHE_ENABLED=False
