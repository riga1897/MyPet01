# Django Settings
DJANGO_ENV=production
SECRET_KEY=your-super-secret-key-here-generate-with-openssl-rand-hex-32
DEBUG=false
ALLOWED_HOSTS=www.mine-craft.su,site.mine-craft.su

# Database (PostgreSQL)
DATABASE_URL=postgres://mypet_user:password@localhost:5432/mypet_db

# Security
CSRF_TRUSTED_ORIGINS=https://www.mine-craft.su,https://site.mine-craft.su
CORS_ALLOWED_ORIGINS=https://www.mine-craft.su,https://site.mine-craft.su

# Caching (Redis)
CACHE_BACKEND=redis
CACHE_LOCATION=redis://127.0.0.1:6379/1

# Static/Media Files
STATIC_ROOT=/var/www/mypet/staticfiles
MEDIA_ROOT=/var/www/mypet/media

# Gunicorn
MYPET_USER=www-data
MYPET_GROUP=www-data

# Logging
LOG_LEVEL=INFO
